wba#!/bin/bash
#PBS -N hard_regime_rl
#PBS -l select=1:ncpus=8:mem=32gb:ngpus=1:gpu_type=A100
#PBS -l walltime=06:00:00
#PBS -q gpu
#PBS -j oe
#PBS -o logs/hard_regime_rl.log
#PBS -m abe
#PBS -M your_email@institution.edu

# ── Move to submission directory ──────────────────────────────────────────────
cd "$PBS_O_WORKDIR"

# ── Load modules (adjust to your cluster's module system) ─────────────────────
module purge
module load cuda/12.1
module load python/3.10        # or anaconda3/2023.09

# ── Activate conda/venv environment ───────────────────────────────────────────
# Option A — conda:
# source activate finrl_env
# Option B — venv:
source /path/to/your/venv/bin/activate

# ── Sanity checks ─────────────────────────────────────────────────────────────
echo "Job ID     : $PBS_JOBID"
echo "Node       : $(hostname)"
echo "GPU(s)     : $CUDA_VISIBLE_DEVICES"
echo "Work dir   : $PBS_O_WORKDIR"
nvidia-smi
python -c "import torch; print('CUDA available:', torch.cuda.is_available())"

# ── Create output directory ────────────────────────────────────────────────────
mkdir -p logs results/hard

# ── Run ───────────────────────────────────────────────────────────────────────
python Finrlmain.py
