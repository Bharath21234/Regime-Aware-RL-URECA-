#!/bin/bash
#PBS -N URC_RL_mv_gae
#PBS -P spms_cspun
#PBS -q gpu_a40
#PBS -M BHARATH007@ntu.edu.sg
#PBS -m abe
#PBS -l walltime=48:00:00
#PBS -l select=1:ncpus=4:ngpus=1:mem=32gb
#PBS -o URC_RL_mv_gae.out
#PBS -e URC_RL_mv_gae.err

module load anaconda2025/2025-gpu
eval "$(/usr/local/anaconda2025/bin/conda shell.bash hook)"
source /home/bharath007/Regime-Aware-RL-URECA-/venv/bin/activate

cd /home/bharath007/Regime-Aware-RL-URECA-/Final

# Back up the existing mv-mode results (pre-GAE/normalization/LR-annealing fix)
# before this run overwrites results/hard/ and results/moe/, so both versions
# can be compared once this finishes.
if [ -d results/hard ] && [ ! -d results/hard_old_mechanics_backup ]; then
    cp -r results/hard results/hard_old_mechanics_backup
fi
if [ -d results/moe ] && [ ! -d results/moe_old_mechanics_backup ]; then
    cp -r results/moe results/moe_old_mechanics_backup
fi

python -u run.py --variant both --seeds 3 --reward_mode mv
